{
  "kind": "collectionType",
  "collectionName": "image_sections",
  "info": {
    "singularName": "image-section",
    "pluralName": "image-sections",
    "displayName": "Image Section"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "textTitle": {
      "type": "string",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "bodyText": {
      "type": "text",
      "required": true
    },
    "variableImage": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "left",
        "right"
      ]
    }
  }
}
